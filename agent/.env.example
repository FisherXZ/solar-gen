ANTHROPIC_API_KEY=sk-ant-...
TAVILY_API_KEY=tvly-...
# Optional: structured extraction from JS-heavy pages (portfolio sites, PDFs)
# Enables the firecrawl_extract tool. If unset, the tool returns an error and
# the agent falls back to fetch_page.
FIRECRAWL_API_KEY=fc-...
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
# Optional: used by the embedding-based context filter (ContextCompressor) in the v3
# research loop. If unset, semantic filtering is skipped and all page content is passed
# through. Set to a valid OpenAI key to enable relevance scoring.
OPENAI_API_KEY=sk-...
